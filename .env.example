# Local dev (Postgres on host). With `docker compose up` from repo root, use:
# DATABASE_URL=postgres://openproof:openproof@localhost:5432/openproof
# (compose maps postgres:5432 to host; inside Docker the API uses hostname `postgres`.)
DATABASE_URL=postgres://openproof:openproof@localhost:5432/openproof
BITCOIN_RPC_URL=https://bitcoin-core.cubo.caeher.com/
BITCOIN_RPC_USER=bitcoin_caeher
BITCOIN_RPC_PASSWORD=bitcoin_caeher
# Use 3001 so Next.js can run on 3000 and proxy /api/v1 to this server (see apps/client/next.config.mjs)
LISTEN_ADDR=0.0.0.0:3001
APP_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=openproof_session
SESSION_TTL_HOURS=720
VERIFICATION_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_HOURS=2
SECURE_COOKIES=false
EXPOSE_DEV_AUTH_TOKENS=true
RUST_LOG=openproof_api_server=debug,tower_http=debug
