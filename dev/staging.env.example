# OpenProof staging profile for local validation against Blink staging.
DATABASE_URL=postgres://openproof:openproof@localhost:5432/openproof
APP_ENV=staging
BITCOIN_RPC_URL=https://bitcoin-core.cubo.caeher.com/
BITCOIN_RPC_USER=bitcoin_caeher
BITCOIN_RPC_PASSWORD=bitcoin_caeher
BLINK_API_URL=https://api.staging.blink.sv/graphql
BLINK_API_KEY=
BLINK_WEBHOOK_SECRET=
BILLING_RECONCILE_INTERVAL_SECONDS=30
DOCUMENT_REGISTRATION_CREDIT_COST=1
LISTEN_ADDR=127.0.0.1:3001
APP_BASE_URL=http://localhost:3000
# Requerido fuera de development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_REPLY_TO=
SMTP_TLS_MODE=starttls
SMTP_TIMEOUT_SECONDS=15
SESSION_COOKIE_NAME=openproof_session
SESSION_TTL_HOURS=720
VERIFICATION_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_HOURS=2
SECURE_COOKIES=false
EXPOSE_DEV_AUTH_TOKENS=true
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
VERIFY_RATE_LIMIT_REQUESTS=30
VERIFY_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_RATE_LIMIT_REQUESTS=120
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
RUST_LOG=openproof_api_server=debug,tower_http=debug